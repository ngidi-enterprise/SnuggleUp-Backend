PORT=3000
MONGODB_URI=mongodb://localhost:27017/snuggleup
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
# Set PAYFAST_TEST_MODE=false for real/live PayFast payments
PAYFAST_TEST_MODE=true

# Bob Go test rates only. Keep BOB_ENABLE_MUTATIONS false during manual launch.
BOB_API_BASE_URL=https://api.sandbox.bobgo.co.za/v2/
BOB_API_TOKEN=your_bob_bearer_token
BOB_RATES_PATH=rates
BOB_COLLECTION_COMPANY=SnuggleUp
BOB_COLLECTION_STREET=your_warehouse_street
BOB_COLLECTION_SUBURB=your_warehouse_suburb
BOB_COLLECTION_CITY=Johannesburg
BOB_COLLECTION_PROVINCE=Gauteng
BOB_COLLECTION_POSTAL_CODE=2196
BOB_COLLECTION_COUNTRY=ZA
BOB_ENABLE_MUTATIONS=false
