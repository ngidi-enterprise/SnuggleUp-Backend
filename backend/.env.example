PORT=3000
MONGODB_URI=mongodb://localhost:27017/snuggleup
FRONTEND_URL=https://snuggleup.co.za
BACKEND_URL=https://api.snuggleup.co.za

# PayFast live production checkout
PAYFAST_MERCHANT_ID=your_live_merchant_id
PAYFAST_MERCHANT_KEY=your_live_merchant_key
# Recommended: set a passphrase in PayFast and use the same value here.
PAYFAST_PASSPHRASE=your_live_passphrase
PAYFAST_NO_PASSPHRASE=false
PAYFAST_TEST_MODE=false
# Keep false in production unless you are actively debugging PayFast signatures.
PAYFAST_DEBUG_LOGS=false

# Comma-separated email addresses allowed to manage the store.
ADMIN_EMAILS=owner@example.com

# Bob Go live production rates. Keep BOB_ENABLE_MUTATIONS false during manual launch.
BOB_API_BASE_URL=https://api.bobgo.co.za/v2/
BOB_API_TOKEN=your_bob_bearer_token
BOB_COURIER_RATES_PATH=rates
BOB_RATE_POLL_ATTEMPTS=8
BOB_RATE_POLL_INTERVAL_MS=750
# Wait up to 10 seconds for courier responses before Bob Go returns the rate request.
BOB_RATE_REQUEST_TIMEOUT_MS=10000
# Required for Bob Go rate quotes. Use your real collection or warehouse address.
BOB_COLLECTION_COMPANY=SnuggleUp
BOB_COLLECTION_STREET=your_warehouse_street
BOB_COLLECTION_SUBURB=your_warehouse_suburb
BOB_COLLECTION_CITY=Johannesburg
BOB_COLLECTION_PROVINCE=Gauteng
BOB_COLLECTION_POSTAL_CODE=2196
BOB_COLLECTION_COUNTRY=ZA
BOB_ENABLE_MUTATIONS=false
# Optional but recommended. Add this same value to the Bob Go webhook URL as ?secret=...
BOB_WEBHOOK_SECRET=choose_a_long_random_secret

# Learning Centre article generation and scheduling.
# Add an OpenAI API key only when you are ready to create original AI drafts.
OPENAI_API_KEY=
LEARNING_CENTRE_MODEL=gpt-4o-mini
LEARNING_CENTRE_REPORT_EMAIL=support@snuggleup.co.za
# Use a long random value if you later connect a Render Cron Job to the protected tick endpoint.
LEARNING_CENTRE_CRON_SECRET=
